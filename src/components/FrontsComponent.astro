---
const datos = [
  {
    logo: "logos_front_2024/codeigniter.svg",
    url: "https://tbot.comovas.es/",
    nombre: "CodeIgniter Tbot",
    descripcion: "Proyecto desarrollado en PHP con CodeIgniter para Tbot.",
  },
  {
    logo: "logos_front_2024/express.svg",
    url: "https://github.com/sergiocomovas/00_proyecto_svelte_backend2",
    nombre: "Express.js API",
    descripcion: "API desarrollada con Node.js y Express.js (en pausa).",
  },
  {
    logo: "logos_front_2024/strapi.svg",
    url: "https://sbot.comovas.es/",
    nombre: "Strapi Sbot",
    descripcion: "Headless CMS desarrollado con Node.js y Strapi.",
  },
  {
    logo: "logos_front_2024/gsheet.svg",
    url: "https://github.com/sergiocomovas/00_proyecto_svelte_backend2",
    nombre: "Gsx2json Gbot",
    descripcion: "Headless CMS desarrollado con Node.js y Gsx2json (en pausa).",
  },
  {
    logo: "logos_front_2024/telegram.svg",
    url: "https://telegraph.comovas.es",
    nombre: "Telegraph",
    descripcion: "Headless CMS desarrollado con Node.js y Telegraph.",
  },
  {
    logo: "logos_front_2024/knex.svg",
    url: "https://knexjs.org/",
    nombre: "Knex.js",
    descripcion: "Constructor de consultas SQL para Node.js.",
  },
];
---

<section class="max-w-6xl mx-auto px-4 py-8">
  <!-- Información para Reclutadores -->
  <div class="grid grid-cols-1 mb-6">
    <h3 class="hidden text-center md:block font-bold">
      Información para Reclutadores
    </h3>
  </div>

  <!-- Open to Work -->
  <div class="card bg-base-200 border border-accent shadow-lg mb-6">
    <div class="card-body p-4">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="mb-4 md:mb-0 col-span-4 md:col-span-3">
          <div class="bg-accent text-base-100 p-4 rounded-lg mb-2">
            <h2 class="text-2xl font-bold mb-2">¡OPEN TO WORK!</h2>
            <p class="text-md">
              Explora mis proyectos en <a target="_blank" href="https://cosasdev.comovas.es" class="shine link font-bold">React</a>,
              <a target="_blank" href="https://sidet.cosasdev.comovas.es/#/tareas" class="shine link font-bold">Vue, Mysql y PHP</a>
              de entrevistas técnicas en 2022 que me abrieron las puertas al éxito profesional.
              Lee sobre mi transformación en
              <a target="_blank" href="https://www.linkedin.com/pulse/scrum-est%C3%A1-a%C3%BAn-de-moda-sergio-r-gonz%C3%A1lez-fbnwe" class="shine link font-bold">Scrum Master profesional</a>.
            </p>
            <p class="font-bold text-lg">
              Revisa mi CV y conecta conmigo en LinkedIn.
            </p>
          </div>
        </div>
        <div class="col-span-4 md:col-span-1 w-full flex flex-col justify-end items-center">
          <a href="https://www.linkedin.com/in/sergiocomovas/" target="_blank" class="btn btn-accent rounded-full">
            🚀 ¡VER CV EN MI PERFIL DE LINKEDIN!
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Explora APIs y Frontends -->
  <div class="grid grid-cols-1 mb-4">
    <h3 class="hidden text-center md:block font-bold">
      Explora mis APIS y Frontends
    </h3>
  </div>

  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-6">
    {datos.map((d) => (
      <a
        target="_blank"
        class="card bg-base-200 border border-base-300 hover:border-accent hover:shadow-lg transition-all p-4"
        href={d.url}
      >
        <div class="card-body p-2">
          <span class="inline-block rounded-lg bg-base-100 p-3">
            <img src={d.logo} alt={d.nombre} loading="lazy" />
          </span>
          <span class="mt-2 font-bold">{d.nombre}</span>
          <p class="hidden sm:block text-sm text-base-content/60">
            {d.descripcion}
          </p>
        </div>
      </a>
    ))}
  </div>

  <!-- El inglés es para todos (Preply) -->
  <div class="grid grid-cols-1 mt-6 mb-4">
    <h3 class="hidden text-center md:block font-bold">
      El inglés es para todos
    </h3>
  </div>

  <div class="card bg-base-200 border border-accent shadow-lg">
    <div class="card-body p-4">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
        <div class="mb-4 md:mb-0 col-span-1 md:col-span-2 p-4 rounded-lg bg-base-100">
          <img loading="lazy" class="w-1/2" src="/logos_preply/preply.png" alt="Preply Logo" />
          <p class="text-sm">
            <span class="text-xl">
              <code class="badge badge-neutral mr-2">LOGRO DESBLOQUEADO</code>
              Tengo más de 300 horas de práctica hablada, avalado por la certificación de la academia de idiomas PREPLY.
            </span>
          </p>
        </div>

        <div class="col-span-1 md:col-span-3 p-4">
          <p>
            Aprender inglés como adulto resultó una tarea aburrida hasta que
            tuve la posibilidad de hacer clases online con un tutor personal.
            Eso me hizo ser gran defensor de este método de aprendizaje.
          </p>
          <p class="font-bold mt-2">
            En mi artículo te lo explico todo. Usa el enlace (referido) para
            obtener un descuento para tu primera clase.
          </p>

          <div class="flex flex-col gap-2 mt-3">
            <a href="https://www.linkedin.com/pulse/ingl%C3%A9s-en-300-horas-sergio-r-gonz%C3%A1lez-goarf/" target="_blank" class="btn btn-neutral rounded-full">
              📢 LEER ARTÍCULO
            </a>
            <a href="https://preply.com/es/?pref=MTEwMTEwMg==&id=1704804102.353758" target="_blank" class="btn btn-outline rounded-full">
              🥰 ¡OBTENER DESCUENTO!
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
