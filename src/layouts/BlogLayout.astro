---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHeadComponent.astro";
import Footer from "../components/FooterComponent.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Menu from "../components/MenuHorizontalComponent.astro";
import LectorComponent from "../components/LectorComponent";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

const baseImage: string = heroImage ?? "/post_img/placeholder.png";
---

<html lang="es" class="overflow-x-hidden">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body class="min-h-screen grid bg-base-100 text-base-content" style="grid-template-rows: auto 1fr auto;">
    <Menu />

    <main class="mx-auto w-full max-w-6xl px-4 py-8 grid gap-6"
          style="grid-template-columns: 30% 65%;">
      <aside class="hidden md:block">
        <div class="sticky top-4 p-3">
          <a title="volver al inicio" href="/">
            <img
              transition:name={title.replace(/[^A-Za-z0-9]/gi, "")}
              width={200}
              height={200}
              src={baseImage}
              alt={description}
              class="w-full h-auto rounded-lg"
            />
          </a>
          <LectorComponent client:load />
        </div>
      </aside>

      <article class="prose max-w-none">
        <div class="mb-5">
          <div class="text-sm text-secondary">
            <FormattedDate date={pubDate} />
            {
              updatedDate && (
                <div class="text-secondary">
                  Last updated on <FormattedDate date={updatedDate} />
                </div>
              )
            }
          </div>
          <h1 class="text-5xl font-bold leading-tight text-transparent bg-gradient-to-r from-purple-500 to-pink-500 bg-clip-text mt-2">
            {title}
          </h1>
          <hr class="my-3 border-base-300" />
        </div>
        <slot />
      </article>
    </main>

    <Footer />
  </body>
</html>

<style>
  /* Responsive: 1 columna en móvil */
  @media (max-width: 768px) {
    body > main {
      grid-template-columns: 1fr !important;
    }
  }
</style>
