---
/**
 * Animaciones GSAP selectivas para web.comovas.es
 * Fade + slide-up al entrar viewport (NO se aplica a carruseles)
 */
---

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Animar secciones principales (NO carruseles, NO globe)
  const sections = document.querySelectorAll('[data-gsap]');
  sections.forEach((section) => {
    gsap.fromTo(
      section,
      { opacity: 0, y: 50 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: section,
          start: 'top 85%',
          toggleActions: 'play none none none',
        },
      }
    );
  });
</script>
