---
import Cookie from "../components/CookieComponent";
import Kofi from "./KofiComponent";
import { Image } from "astro:assets";

import imgScrum from "../../public/PSM1.svg";

const today = new Date();
---

<!--FOOTER-->
<footer class="footer footer-center md:footer-horizontal bg-base-200 text-base-content p-6 rounded-t-lg">
  <div class="md:text-left">
    <p class="mb-0">
      CORREO <a class="link link-primary" title="sergio@comovas.es" href="mailto:sergio@comovas.es">sergio@comovas.es</a>
      | <a href="/legal" class="link link-primary" title="Aviso Legal y Privacidad">Aviso Legal</a>
      <Kofi />
    </p>
  </div>

  <div class="flex items-center gap-4">
    <!-- Toggle de tema claro/oscuro -->
    <label class="swap swap-rotate" aria-label="Cambiar tema">
      <input type="checkbox" id="theme-toggle" class="theme-controller" value="dark" />
      <!-- Icono sol (tema claro activo) -->
      <svg class="swap-off h-8 w-8 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"/></svg>
      <!-- Icono luna (tema oscuro activo) -->
      <svg class="swap-on h-8 w-8 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.86a8.05,8.05,0,0,1,.73-3.37A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63h.27A8.13,8.13,0,0,1,12.14,19.73Z"/></svg>
    </label>
  </div>

  <div class="md:text-right">
    <p class="mb-0 opacity-50">
      COMOVAS.ES &copy; {today.getFullYear()}
      <br />
      <Image class="z-10 inline" src={imgScrum} alt="Scrum Master" title="Professional Scrum Master PSMI" width="250" />
    </p>
  </div>
</footer>

<!--FIN DE FOOTER-->
<Cookie client:load />

<script is:inline>
  // Restaurar tema guardado
  (function() {
    const saved = localStorage.getItem('theme');
    const toggle = document.getElementById('theme-toggle');
    if (saved === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
      if (toggle) toggle.checked = true;
    } else if (saved === 'light') {
      document.documentElement.setAttribute('data-theme', 'light');
      if (toggle) toggle.checked = false;
    }
    // Toggle listener
    if (toggle) {
      toggle.addEventListener('change', (e) => {
        if (e.target.checked) {
          document.documentElement.setAttribute('data-theme', 'dark');
          localStorage.setItem('theme', 'dark');
        } else {
          document.documentElement.setAttribute('data-theme', 'light');
          localStorage.setItem('theme', 'light');
        }
      });
    }
  })();
</script>
