---
import BaseHead from "../components/BaseHeadComponent.astro";
import Footer from "../components/FooterComponent.astro";
import Menu from "../components/MenuHorizontalComponent.astro";

import { getCollection } from "astro:content";
import GlobeBackgroundComponent from "../components/GlobeBackgroundComponent.astro";
import Cols from "../components/ColsComponent.tsx";
import EstaWeb from "../components/EstaWebComponent.tsx";
import Fronts from "../components/FrontsComponent.astro";
import IntroLinks from "../components/IntroLinksComponent.astro";
import GsapAnimations from "../components/GsapAnimations.astro";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 15);
const iaPosts = (await getCollection("blog_ia"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 15);
---

<!doctype html>
<html lang="es" class="overflow-x-hidden" data-theme="dark">
  <head>
    <BaseHead title="Sergio 🙋 『CØMO』『VAS』" description="Página Principal" />
  </head>
  <body class="bg-base-100 text-base-content overflow-x-hidden min-h-screen grid" style="grid-template-rows: auto 1fr auto;">
    <Menu />

    <main class="w-full max-w-6xl mx-auto px-4">
      <!-- Hero: jumbo marquee + globo de fondo -->
      <GlobeBackgroundComponent />

      <!-- Sección stack tecnológico -->
      <section class="mt-10 mb-10" data-gsap>
        <div class="text-sm uppercase tracking-wider opacity-60 px-2 mb-4">
          // <span class="neon">STACK</span> TECNOLÓGICO
        </div>
        <div class="mb-10">
          <EstaWeb client:only />
        </div>
      </section>

      <!-- Blog posts -->
      <section class="mb-10" data-gsap>
        <div class="text-sm uppercase tracking-wider opacity-60 px-2 mb-4">
          // <span class="neon">BLOG</span> ÚLTIMAS PUBLICACIONES
        </div>
        <Cols posts={posts} basePath="/blog" client:only />
      </section>

      <!-- Blog IA -->
      <section class="mb-10" data-gsap>
        <div class="text-sm uppercase tracking-wider opacity-60 px-2 mb-4">
          // <span class="purple">IA</span> PUBLICACIONES INTELIGENCIA ARTIFICIAL
        </div>
        <Cols posts={iaPosts} basePath="/blog_ia" client:only />
      </section>

      <Fronts />
      <IntroLinks />
    </main>

    <GsapAnimations />
    <Footer />
  </body>
</html>
