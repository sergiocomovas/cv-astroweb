---
const enlaces = [
  { nombre: "sergiocomovas", desc: "Repositorio de GITHUB", url: "https://github.com/sergiocomovas/", icon: "🐙" },
  { nombre: "@SergioComoVas", desc: "Cuenta de 𝕏 principal", url: "https://x.com/sergiocomovas", icon: "𝕏" },
  { nombre: "@SergioComoVas", desc: "Cuenta de Threads", url: "https://www.threads.net/@sergiocomovas", icon: "🧵" },
  { nombre: "Palma Info", desc: "Comunidad y grupo de Telegram", url: "https://twitter.com/i/communities/1527611374611857410", icon: "📢" },
];

const duplicated = [...enlaces, ...enlaces, ...enlaces];
---

<section class="row-full relative mb-10" data-gsap>
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-sm uppercase tracking-wider opacity-60 mb-4">
      // <span class="neon">CONNECT</span> REDES Y ENLACES
    </div>
    <div class="marqy w-full" data-direction="left" data-pause-on-hover>
      <div class="marqy-inner">
        {duplicated.map((enlace) => (
          <div class="marqy-content">
            <a href={enlace.url} target="_blank"
              class="shine flex items-center gap-3 p-3 mx-2 bg-white/5 border border-white/10 rounded-lg min-w-[280px] flex-shrink-0 transition-all duration-150 hover:border-primary hover:bg-white/10">
              <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-lg">
                {enlace.icon}
              </div>
              <div class="flex flex-col">
                <span class="font-bold text-sm whitespace-nowrap">{enlace.nombre}</span>
                <span class="text-xs opacity-40 whitespace-nowrap">{enlace.desc}</span>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
