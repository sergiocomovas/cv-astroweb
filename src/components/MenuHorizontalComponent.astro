---
const links = [
  { text: "Inicio", href: "/", class: "hidden md:inline-flex" },
  { text: "Acerca de", href: "/acerca", class: "" },
];
---

<header class="sticky top-0 inset-x-0 z-50 flex items-center justify-between backdrop-blur-sm border-b border-white/10 p-5 bg-black/70">
  <h1 class="text-lg font-bold uppercase tracking-wider">
    <a href="/" class="flex items-baseline gap-1">
      <span>COMO</span><span class="neon">VAS</span>
      <span class="text-xs opacity-40 ml-1">v_2026</span>
    </a>
  </h1>
  <nav>
    <ul class="flex items-center gap-6">
      {links.map((link) => (
        <li class={link.class}>
          <a href={link.href} class="text-sm uppercase hover-flicker group">
            [ <span class="group-hover:text-primary transition-colors">{link.text}</span> ]
          </a>
        </li>
      ))}
      <li>
        <a href="https://github.com/sergiocomovas" target="_blank" class="text-sm uppercase hover-flicker group">
          [ <span class="group-hover:text-primary transition-colors">GitHub</span> ]
        </a>
      </li>
    </ul>
  </nav>
</header>
