---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHeadComponent.astro";
import Footer from "../components/FooterComponent.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Menu from "../components/MenuHorizontalComponent.astro";
import LectorComponent from "../components/LectorComponent";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
const baseImage: string = heroImage ?? "/post_img/placeholder.png";
---

<html lang="es" class="overflow-x-hidden" data-theme="dark">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body class="bg-base-100 text-base-content overflow-x-hidden min-h-screen grid" style="grid-template-rows: auto 1fr auto;">
    <Menu />

    <main class="w-full max-w-6xl mx-auto px-4 py-8 grid gap-6" style="grid-template-columns: 1fr;">
      <div class="md:grid md:gap-6" style="grid-template-columns: 30% 65%;">
        <!-- Aside con imagen y lector -->
        <aside class="hidden md:block">
          <div class="sticky top-20 p-3">
            <a title="volver al inicio" onclick="javascript:window.history.back()">
              <img
                transition:name={title.replace(/[^A-Za-z0-9]/gi, "")}
                width={200}
                height={200}
                src={baseImage}
                alt={description}
                class="rounded-lg w-full"
              />
            </a>
            <LectorComponent client:load />
          </div>
        </aside>

        <!-- Article -->
        <article class="overflow-x-hidden">
          <div class="prose prose-invert max-w-none p-4">
            <div class="mb-4">
              <div class="text-sm opacity-50">
                <FormattedDate date={pubDate} />
                {updatedDate && (
                  <div class="text-secondary">
                    Last updated on <FormattedDate date={updatedDate} />
                  </div>
                )}
              </div>
              <h1 class="text-3xl md:text-5xl font-bold leading-tight mt-2 text-transparent bg-gradient-to-r from-primary to-secondary bg-clip-text">
                {title}
              </h1>
              <hr class="my-3 border-white/10" />
            </div>
            <slot />
          </div>
        </article>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  body {
    font-family: ui-monospace, "SF Mono", Menlo, Monaco, Consolas, monospace;
  }
  .prose :where(code):not(pre > code) {
    background: rgba(255,255,255,0.05);
    border-radius: 0.25rem;
    padding: 0.1rem 0.4rem;
  }
  .prose pre {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.5rem;
  }
  .prose a {
    color: var(--color-primary);
  }
  .prose blockquote {
    border-left: 4px solid var(--color-primary);
    background: rgba(255,255,255,0.03);
    padding: 0.5rem 1rem;
    border-radius: 0 0.5rem 0.5rem 0;
  }
  @media (max-width: 768px) {
    main { grid-template-columns: 1fr; }
  }
</style>
